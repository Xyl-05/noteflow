{
  "name": "noteflow",
  "version": "1.0.0",
  "description": "NoteFlow - Creative Note Management App",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "php -S localhost:8000 -t php-api",
    "build": "tsc && vite build",
    "build:frontend": "tsc && vite build",
    "start": "php -S localhost:8000 -t php-api",
    "check": "tsc --noEmit",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^0.314.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1"
  }
}
